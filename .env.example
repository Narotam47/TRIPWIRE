# Copy this file to .env and fill in your credentials.
# .env is git-ignored — never commit real secrets.

# GitHub Personal Access Token (classic or fine-grained, read-only scope is sufficient)
# Needed for: GitHub REST API rate-limit headroom (5 000 req/hr authenticated vs 60 unauthenticated)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX

# Anthropic API key
# Needed for: LLM-jury change classification and agentic behavioral validation
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX
